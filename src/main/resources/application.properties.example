# Database Configuration
spring.datasource.url=jdbc:postgresql://localhost:5432/chatify
spring.datasource.username=${DB_USERNAME:chatify_user}
spring.datasource.password=${DB_PASSWORD:chatify_password}
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA/Hibernate Settings
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# JWT Configuration
jwt.secret=${JWT_SECRET:defaultBase64EncodedSecretKeyHere12345678901234567890123456789012}
jwt.expiration-ms=3600000
app.jwt.refresh-token.expiration-ms=604800000

# File Upload Configuration
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
file.upload-dir=./uploads

# WebSocket Configuration
spring.websocket.allowed-origins=*

# Server Configuration
server.port=8080
